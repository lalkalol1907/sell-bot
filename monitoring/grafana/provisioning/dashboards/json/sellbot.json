      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Лиды созданы (matching)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "expr": "matching_leads_created_total", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Спам отфильтрован",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "expr": "sum(matching_spam_filtered_total)", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Уведомления доставлены (бот)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "expr": "seller_bot_leads_delivered_total", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Алерты воркеров",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "expr": "seller_bot_worker_alerts_total", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Обработка сообщений (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(matching_messages_total[5m])) by (result)", "legendFormat": "{{result}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Спам-фильтр по причинам",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(matching_spam_filtered_total[5m])) by (reason)", "legendFormat": "{{reason}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Логи sellbot (Loki)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{project=\"sell-bot\"} |~ \"(?i)error|warn|lead|spam|worker\"", "refId": "A" }
      ]
    }
