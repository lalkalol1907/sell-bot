# --- Edge proxy (Caddy, deploy/docker-compose.prod.yml) ---
# DNS A/AAAA for each domain must point to the host; ports 80 and 443 must be open.
LOGIN_DOMAIN=login.YOUR_DOMAIN
APP_DOMAIN=app.YOUR_DOMAIN
BOT_DOMAIN=bot.YOUR_DOMAIN
# Optional: Let's Encrypt expiry notifications
ACME_EMAIL=admin@example.com

# --- Infrastructure ---
DATABASE_URL=postgres://sellbot:sellbot@db:5432/sellbot
REDIS_URL=redis://redis:6379/0
NATS_URL=nats://nats:4222

# --- Internal gRPC auth (metadata: x-internal-grpc-token) ---
INTERNAL_GRPC_TOKEN=

# --- Seller Bot ---
BOT_TOKEN=
BOT_USERNAME=
CORE_GRPC_ADDR=core:50051
LOGIN_WEB_URL=https://login.YOUR_DOMAIN/miniapp/
# polling (local dev, single replica) | webhook (prod, horizontal scale)
BOT_TRANSPORT=polling
HTTP_PORT=8080
# Required when BOT_TRANSPORT=webhook (public URL must end with WEBHOOK_PATH)
WEBHOOK_URL=https://bot.YOUR_DOMAIN/telegram/webhook
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=
WEBHOOK_REGISTER_ON_STARTUP=true

# --- HTTP Gateway (Bun API) ---
JWT_SECRET=change-me-in-production
WORKER_LOGIN_GRPC_ADDR=worker-engine:50053
LOGIN_ROUTE_TTL_SEC=600
CORS_ORIGINS=https://login.YOUR_DOMAIN,https://app.YOUR_DOMAIN

# --- Web UI services (separate nginx containers) ---
# login-miniapp: http://localhost:8081/miniapp/
# seller-dashboard: http://localhost:8082/dashboard/

# --- Worker Engine ---
DEV_INJECT_MESSAGE=
OWNER_SELLER_ID=1
WORKER_ID=1
TG_API_ID=
TG_API_HASH=
SESSION_ENCRYPTION_KEY=
WORKER_SESSION_PATH=/data/session.json
LISTEN_ALL_CHATS=true
LOGIN_GRPC_PORT=50053

# --- Matching ---
CORE_GRPC_ADDR=core:50051
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
NLP_V2_ENABLED=false
NLP_V2_SEMANTIC=true
NLP_V2_INTENT_ML=true
NLP_V2_NORMALIZE=false
MODELS_SKIP_S3=true
MODELS_LOCAL_DIR=/data/models
MODELS_S3_ENDPOINT=
MODELS_S3_BUCKET=
MODELS_S3_PREFIX=
MODELS_S3_VERSION=
MODELS_S3_REGION=
MODELS_S3_ACCESS_KEY=
MODELS_S3_SECRET_KEY=
# Publish: ./services/matching/scripts/publish_models.sh <version>  (reads vars above from .env)
VARIANT_STORAGE_MISMATCH_MULT=0.45
VARIANT_STORAGE_MISSING_MULT=0.72
VARIANT_COLOR_MISMATCH_MULT=0.50
VARIANT_COLOR_MISSING_MULT=0.78

# --- Core ---
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/sellbot
SPRING_DATASOURCE_USERNAME=sellbot
SPRING_DATASOURCE_PASSWORD=sellbot

# --- Optional ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
