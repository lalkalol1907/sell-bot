# Production .env for docker-compose.prod.yml
# GitHub secret DEPLOY_DOTENV — полное содержимое этого файла с реальными значениями.
# CI дописывает IMAGE_TAG и *_IMAGE_NAME — не включайте их сюда.
#
# openssl rand -hex 32     → INTERNAL_GRPC_TOKEN, JWT_SECRET, WEBHOOK_SECRET, POSTGRES_PASSWORD
# openssl rand -base64 32  → SESSION_ENCRYPTION_KEY

# --- Caddy / TLS ---
LOGIN_DOMAIN=login.YOUR_DOMAIN
APP_DOMAIN=app.YOUR_DOMAIN
BOT_DOMAIN=bot.YOUR_DOMAIN
GRAFANA_DOMAIN=grafana.YOUR_DOMAIN
ACME_EMAIL=admin@example.com

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- PostgreSQL ---
POSTGRES_USER=sellbot
POSTGRES_PASSWORD=
POSTGRES_DB=sellbot

# --- Internal gRPC ---
INTERNAL_GRPC_TOKEN=

# --- Telegram Bot ---
BOT_TOKEN=
BOT_USERNAME=          # без @; build-arg VITE_BOT_USERNAME для seller-dashboard
LOGIN_WEB_URL=https://login.YOUR_DOMAIN/miniapp/  # seller-dashboard build + core handoff URL
WEBHOOK_URL=https://bot.YOUR_DOMAIN/telegram/webhook
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# --- HTTP Gateway ---
JWT_SECRET=
CORS_ORIGINS=https://login.YOUR_DOMAIN,https://app.YOUR_DOMAIN
WORKER_LOGIN_GRPC_ADDR=worker-engine:50053
LOGIN_ROUTE_TTL_SEC=600

# --- Worker Engine ---
TG_API_ID=
TG_API_HASH=
SESSION_ENCRYPTION_KEY=
LISTEN_ALL_CHATS=false

# --- Matching models (S3) ---
# Local dev: MODELS_SKIP_S3=true (default in docker-compose) + bundle mount in docker-compose.yml
# Production: publish bundle first, then MODELS_SKIP_S3=false
#   make train
#   make publish MODELS_VERSION=2026.06.18-1
# Expected S3 layout: s3://$BUCKET/$PREFIX/matching/<version>/manifest.json
MODELS_SKIP_S3=false
MODELS_S3_ENDPOINT=
MODELS_S3_BUCKET=
MODELS_S3_PREFIX=models/
MODELS_S3_VERSION=
MODELS_S3_REGION=
MODELS_S3_ACCESS_KEY=
MODELS_S3_SECRET_KEY=
MODELS_WATCH_ENABLED=true
MODELS_WATCH_INTERVAL=60
