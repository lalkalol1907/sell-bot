# Env & secrets
.env
.env.*
!.env.example
monitoring/.env
*.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.cursor/
*.iml
*.swp
*.swo

# Logs & coverage
*.log
.coverage
htmlcov/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# --- Core (Kotlin / Gradle) ---
services/core/build/
services/core/.gradle/
services/core/out/

# --- Worker Engine (Go) ---
services/worker-engine/bin/
services/worker-engine/dist/
services/worker-engine/worker-engine

# --- Matching (Python) ---
services/matching/build/
services/matching/dist/
services/matching/.venv/
services/matching/venv/
services/matching/__pycache__/
services/matching/**/__pycache__/
services/matching/**/*.pyc
services/matching/*.egg-info/
services/matching/**/.eggs/
# Staging dir for publish (not committed artifacts)
services/matching/.bundle-staging/
# Trained models (generated locally via make train)
services/matching/models/*.joblib
services/matching/models/*.meta.json
services/matching/models/bundles/
# Keep canonical thresholds template for reference
!services/matching/models/semantic_thresholds.json
# Generated eval reports (baseline kept for regression)
services/matching/reports/*
!services/matching/reports/recognition_baseline.json
# Export stub output
services/matching/data/intent_export.jsonl
# Generated proto stubs (run: make gen-proto-python)
services/matching/app/generated/*
!services/matching/app/generated/__init__.py

# --- Node / Bun (TypeScript) ---
node_modules/
**/node_modules/
*.tsbuildinfo

# --- Seller Bot (Bun / TypeScript) ---
services/seller-bot/dist/
services/seller-bot/.bun/

# --- HTTP Gateway (Bun / TypeScript) ---
# --- Web monorepo (Vite / Bun) ---
services/web/apps/*/dist/

# Telegram session files (never commit)
*.session
session_*
**/session.json
